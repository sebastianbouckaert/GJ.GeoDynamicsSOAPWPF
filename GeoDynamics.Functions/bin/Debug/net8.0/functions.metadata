[
  {
    "name": "ProcessSqlTasks",
    "scriptFile": "GeoDynamics.Functions.dll",
    "entryPoint": "GeoDynamics.Functions.SqlProcessorFunction.Run",
    "language": "dotnet-isolated",
    "properties": {
      "IsCodeless": false
    },
    "bindings": [
      {
        "name": "myTimer",
        "direction": "In",
        "type": "timerTrigger",
        "schedule": "0 */2 * * * *",
        "properties": {}
      }
    ]
  }
]